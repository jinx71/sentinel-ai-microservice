# --- Service ---
APP_NAME=sentinel-ai-microservice
APP_VERSION=1.0.0
LOG_LEVEL=INFO

# --- Model ---
MODEL_PATH=app/artifacts/model.joblib
CONTAMINATION=0.02
RANDOM_SEED=42

# --- Optional LLM explanations (graceful degradation when unset) ---
# Set ENABLE_LLM_EXPLANATIONS=true AND provide a key to enable the /explain LLM path.
ENABLE_LLM_EXPLANATIONS=false
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
